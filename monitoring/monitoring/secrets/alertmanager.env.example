# Alertmanager environment variable reference
# Copy this file to alertmanager.env and fill in real values.

# ── SMTP (email) ─────────────────────────────────────────────────────────────
#
# ALERTMANAGER_SMTP_HOST
#   Format: host:port
#   Gmail:            smtp.gmail.com:587
#   SendGrid:         smtp.sendgrid.net:587
#   AWS SES (eu):     email-smtp.eu-west-1.amazonaws.com:587
#
# ALERTMANAGER_SMTP_FROM
#   The From: address that alert emails will appear to come from.
#   Must match the authenticated account or be an alias allowed by the provider.
#
# ALERTMANAGER_SMTP_USERNAME
#   SMTP auth username. For Gmail this is your full email address.
#   For SendGrid use the literal string: apikey
#
# ALERTMANAGER_SMTP_PASSWORD
#   Gmail: use an App Password (Google Account → Security → App Passwords).
#   SendGrid: use the API key as the password.
#   CONSTRAINT: Do not use single-quote (') or backslash (\) characters —
#   they break YAML env-var expansion. Use a different special char if needed.
#
# ALERTMANAGER_EMAIL_TO
#   Recipient address for all alerts. Can be a comma-separated list for
#   multiple recipients:  oncall@yourdomain.com,backup@yourdomain.com

ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_FROM=alerts@yourdomain.com
ALERTMANAGER_SMTP_USERNAME=alerts@yourdomain.com
ALERTMANAGER_SMTP_PASSWORD=your-16-char-gmail-app-password
ALERTMANAGER_EMAIL_TO=oncall@yourdomain.com

# ── Webhook (optional) ───────────────────────────────────────────────────────
#
# ALERTMANAGER_WEBHOOK_URL
#   Generic webhook endpoint for critical alerts.
#   Examples:
#     Slack incoming webhook:  https://hooks.slack.com/services/T.../B.../xxx
#     PagerDuty Events v2:     https://events.pagerduty.com/v2/enqueue
#     Custom endpoint:         https://your-app.example.com/alertmanager-hook
#
#   Also uncomment the webhook_configs block in alertmanager.yml to activate.
#
# ALERTMANAGER_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
